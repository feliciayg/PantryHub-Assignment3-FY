<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/inventory_background"
    tools:theme="@style/Theme.InventoryHub">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="@dimen/page_horizontal_padding"
        android:paddingEnd="@dimen/page_horizontal_padding">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/searchLayout"
            style="@style/Widget.InventoryHub.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/search_items_identifiers"
            app:endIconDrawable="@drawable/ic_barcode_scan"
            app:endIconMode="custom"
            app:startIconDrawable="@drawable/ic_search">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/searchEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:minHeight="@dimen/form_field_height"
                android:singleLine="true" />
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/items_control_height"
            android:layout_marginTop="@dimen/space_sm"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.chip.Chip
                android:id="@+id/locationSelector"
                style="@style/Widget.InventoryHub.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxWidth="150dp"
                android:singleLine="true"
                android:textColor="@color/inventory_text_primary"
                android:textStyle="bold"
                app:chipIcon="@drawable/ic_chevron_down"
                app:chipIconTint="@color/inventory_text_secondary"
                app:chipIconVisible="true"
                tools:text="All Locations" />

            <com.google.android.material.chip.Chip
                android:id="@+id/groupButton"
                style="@style/Widget.InventoryHub.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_sm"
                android:text="@string/group_by"
                android:textStyle="bold"
                app:chipIcon="@drawable/ic_chevron_down"
                app:chipIconTint="@color/inventory_text_secondary"
                app:chipIconVisible="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/inStockChip"
                style="@style/Widget.InventoryHub.Chip.Assist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_sm"
                android:text="@string/in_stock"
                android:textStyle="bold"
                android:checkable="true" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/sortButton"
                android:layout_width="@dimen/items_control_height"
                android:layout_height="@dimen/items_control_height"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/sort_items"
                android:src="@drawable/ic_sort"
                app:tint="@color/inventory_text_secondary" />
        </LinearLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/loadingIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:indeterminate="true"
            android:visibility="gone" />

        <TextView
            android:id="@+id/needToBuyHeaderTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:text="@string/low_stock_need_to_buy"
            android:textColor="@color/inventory_text_primary"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/emptyTextView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/space_lg"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/empty_items_filtered"
            android:textColor="@color/inventory_text_secondary"
            android:textSize="@dimen/text_size_body"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/inventoryRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/space_sm"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/items_list_bottom_padding"
            tools:listitem="@layout/item_inventory_item" />

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addInventoryItemFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="@dimen/space_lg"
        android:layout_marginBottom="@dimen/space_md"
        android:contentDescription="@string/add_inventory_item"
        app:backgroundTint="@color/inventory_primary"
        app:srcCompat="@drawable/ic_add" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
