<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/inventory_surface"
    android:orientation="vertical"
    android:paddingBottom="@dimen/space_lg">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/space_sm"
        android:layout_marginBottom="@dimen/space_md"
        android:background="@color/inventory_outline" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/item_form_horizontal_padding"
        android:paddingEnd="@dimen/item_form_horizontal_padding"
        android:paddingBottom="@dimen/space_sm"
        android:text="@string/item_photo"
        android:textColor="@color/inventory_text_primary"
        android:textSize="@dimen/text_size_section"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/takePhotoRow"
        style="@style/Widget.InventoryHub.FormRow"
        android:contentDescription="@string/take_photo">

        <ImageView
            android:layout_width="@dimen/home_action_icon_size"
            android:layout_height="@dimen/home_action_icon_size"
            android:layout_marginEnd="@dimen/space_md"
            android:contentDescription="@null"
            android:src="@drawable/ic_camera"
            app:tint="@color/inventory_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/take_photo"
            android:textColor="@color/inventory_text_primary"
            android:textSize="@dimen/text_size_body" />

        <ImageView style="@style/Widget.InventoryHub.FormRowChevron" />
    </LinearLayout>

    <View style="@style/Widget.InventoryHub.FormDivider" />

    <LinearLayout
        android:id="@+id/uploadPhotoRow"
        style="@style/Widget.InventoryHub.FormRow"
        android:contentDescription="@string/upload_photo">

        <ImageView
            android:layout_width="@dimen/home_action_icon_size"
            android:layout_height="@dimen/home_action_icon_size"
            android:layout_marginEnd="@dimen/space_md"
            android:contentDescription="@null"
            android:src="@drawable/ic_upload"
            app:tint="@color/inventory_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/upload_photo"
            android:textColor="@color/inventory_text_primary"
            android:textSize="@dimen/text_size_body" />

        <ImageView style="@style/Widget.InventoryHub.FormRowChevron" />
    </LinearLayout>
</LinearLayout>
