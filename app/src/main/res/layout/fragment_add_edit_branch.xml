<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/inventory_surface"
    android:orientation="vertical"
    tools:theme="@style/Theme.InventoryHub">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        style="@style/Widget.InventoryHub.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/app_bar_height"
        app:navigationIcon="@drawable/ic_close"
        app:titleCentered="true"
        tools:title="New Location" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inventory_outline" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/space_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/page_horizontal_padding"
                android:paddingTop="@dimen/space_xl"
                android:paddingEnd="@dimen/page_horizontal_padding">

                <TextView
                    style="@style/TextAppearance.InventoryHub.PageTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/location_details" />

                <TextView
                    style="@style/TextAppearance.InventoryHub.Caption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xl"
                    android:text="@string/name" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/nameLayout"
                    style="@style/Widget.InventoryHub.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:hint="@string/location_name_placeholder">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/nameEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords"
                        tools:text="Subang Office" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    style="@style/TextAppearance.InventoryHub.Caption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_lg"
                    android:text="@string/memo" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/memoLayout"
                    style="@style/Widget.InventoryHub.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:hint="@string/location_memo_placeholder">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/memoEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top|start"
                        android:inputType="textCapSentences|textMultiLine"
                        android:minLines="4"
                        tools:text="Add relevant notes&#10;(e.g. used for online fulfillment)" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/saveButton"
        style="@style/Widget.InventoryHub.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/page_horizontal_padding"
        android:layout_marginTop="@dimen/space_sm"
        android:layout_marginEnd="@dimen/page_horizontal_padding"
        android:layout_marginBottom="@dimen/page_bottom_padding"
        android:text="@string/save" />
</LinearLayout>
