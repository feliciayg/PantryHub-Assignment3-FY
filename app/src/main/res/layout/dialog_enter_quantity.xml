<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/space_lg"
    android:paddingTop="@dimen/space_sm"
    android:paddingEnd="@dimen/space_lg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/minusButton"
            style="@style/Widget.Material3.Button.OutlinedButton.Icon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:contentDescription="@string/decrease_quantity"
            app:icon="@drawable/ic_minus"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/inventory_primary" />

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/quantityInputEditText"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/space_lg"
            android:layout_marginEnd="@dimen/space_lg"
            android:background="@null"
            android:gravity="center"
            android:hint="@string/zero"
            android:imeOptions="actionDone"
            android:inputType="numberDecimal"
            android:maxLines="1"
            android:singleLine="true"
            android:textColor="@color/inventory_text_primary"
            android:textSize="@dimen/text_size_title" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/plusButton"
            style="@style/Widget.Material3.Button.OutlinedButton.Icon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:contentDescription="@string/increase_quantity"
            app:icon="@drawable/ic_add"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/inventory_primary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/expiryDateGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="@dimen/space_sm"
        android:paddingBottom="@dimen/space_md"
        android:visibility="gone">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="@dimen/space_md"
            android:contentDescription="@string/expiry_date"
            android:src="@drawable/ic_calendar"
            app:tint="@color/inventory_text_secondary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/expiry_date"
            android:textColor="@color/inventory_text_secondary"
            android:textSize="@dimen/text_size_body" />

        <TextView
            android:id="@+id/expiryDateValueTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingStart="@dimen/space_md"
            android:paddingEnd="@dimen/space_sm"
            android:text="@string/select_expiry_date"
            android:textColor="@color/inventory_primary"
            android:textSize="@dimen/text_size_body" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clearExpiryDateButton"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:text="@string/clear" />

        <ImageView
            android:id="@+id/expiryChevronImageView"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@string/select_expiry_date"
            android:src="@drawable/ic_chevron_right"
            app:tint="@color/inventory_text_secondary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/stockPreviewGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/space_md"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="@dimen/space_sm"
            android:paddingBottom="@dimen/space_sm">

            <TextView
                android:id="@+id/currentStockLabelTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/current_stock"
                android:textColor="@color/inventory_text_secondary"
                android:textSize="@dimen/text_size_body" />

            <TextView
                android:id="@+id/currentStockValueTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/inventory_text_primary"
                android:textSize="@dimen/text_size_body"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="@dimen/space_sm"
            android:paddingBottom="@dimen/space_sm">

            <TextView
                android:id="@+id/afterStockLabelTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/after_stock_in"
                android:textColor="@color/inventory_text_secondary"
                android:textSize="@dimen/text_size_body" />

            <TextView
                android:id="@+id/afterStockValueTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/inventory_primary"
                android:textSize="@dimen/text_size_body"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/differenceStockGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingTop="@dimen/space_sm"
            android:paddingBottom="@dimen/space_sm"
            android:visibility="gone">

            <TextView
                android:id="@+id/differenceStockLabelTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/difference"
                android:textColor="@color/inventory_text_secondary"
                android:textSize="@dimen/text_size_body" />

            <TextView
                android:id="@+id/differenceStockValueTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/inventory_primary"
                android:textSize="@dimen/text_size_body"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/extraStockPreviewGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="@dimen/space_sm"
                android:paddingBottom="@dimen/space_sm">

                <TextView
                    android:id="@+id/extraCurrentStockLabelTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/inventory_text_secondary"
                    android:textSize="@dimen/text_size_body" />

                <TextView
                    android:id="@+id/extraCurrentStockValueTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/inventory_text_primary"
                    android:textSize="@dimen/text_size_body"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="@dimen/space_sm"
                android:paddingBottom="@dimen/space_sm">

                <TextView
                    android:id="@+id/extraAfterStockLabelTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/inventory_text_secondary"
                    android:textSize="@dimen/text_size_body" />

                <TextView
                    android:id="@+id/extraAfterStockValueTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/inventory_primary"
                    android:textSize="@dimen/text_size_body"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
