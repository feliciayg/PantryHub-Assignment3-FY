<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="@dimen/item_form_horizontal_padding"
    android:paddingTop="@dimen/space_lg"
    android:paddingEnd="@dimen/item_form_horizontal_padding"
    android:paddingBottom="@dimen/space_md">

    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/inventory_text_primary"
        android:textSize="@dimen/text_size_section"
        android:textStyle="bold" />

    <ImageButton
        android:id="@+id/infoButton"
        android:layout_width="@dimen/item_form_info_size"
        android:layout_height="@dimen/item_form_info_size"
        android:layout_marginStart="@dimen/space_xs"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/attributes_info"
        android:src="@drawable/ic_info"
        android:visibility="gone"
        app:tint="@color/inventory_text_secondary" />
</LinearLayout>
