<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/inventory_surface"
    android:orientation="vertical"
    tools:theme="@style/Theme.InventoryHub">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        style="@style/Widget.InventoryHub.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/app_bar_height"
        app:navigationIcon="@drawable/ic_back"
        app:title="@string/store_details" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inventory_outline" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/space_lg">

            <FrameLayout
                android:id="@+id/imagePickerContainer"
                android:layout_width="@dimen/item_form_image_size"
                android:layout_height="@dimen/item_form_image_size"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/space_lg"
                android:background="@drawable/bg_inventory_image_placeholder"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:id="@+id/storeImageView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/store_image"
                    android:scaleType="centerCrop"
                    tools:src="@drawable/ic_store" />

                <FrameLayout
                    android:layout_width="@dimen/item_form_camera_size"
                    android:layout_height="@dimen/item_form_camera_size"
                    android:layout_gravity="bottom|end"
                    android:layout_marginEnd="-2dp"
                    android:layout_marginBottom="-2dp"
                    android:background="@drawable/bg_camera_overlay_circle">

                    <ImageView
                        android:layout_width="@dimen/home_status_icon_size"
                        android:layout_height="@dimen/home_status_icon_size"
                        android:layout_gravity="center"
                        android:contentDescription="@string/change_store_photo"
                        android:src="@drawable/ic_camera"
                        app:tint="@color/inventory_on_primary" />
                </FrameLayout>
            </FrameLayout>

            <TextView
                style="@style/TextAppearance.InventoryHub.Caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingStart="@dimen/page_horizontal_padding"
                android:paddingTop="@dimen/space_sm"
                android:paddingEnd="@dimen/page_horizontal_padding"
                android:text="@string/store_photo_helper" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/page_horizontal_padding"
                android:paddingTop="@dimen/space_xl"
                android:paddingEnd="@dimen/page_horizontal_padding">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/storeNameLayout"
                    style="@style/Widget.InventoryHub.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/name">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/storeNameEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords"
                        tools:text="JayaGrocer" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/storeDescriptionLayout"
                    style="@style/Widget.InventoryHub.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:hint="@string/description">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/storeDescriptionEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapSentences|textMultiLine"
                        android:maxLines="3"
                        android:minLines="2"
                        tools:text="Main supermarket workspace" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <include layout="@layout/include_inventoryhub_section_band" />

            <TextView
                style="@style/Widget.InventoryHub.FormSectionTitle"
                android:text="@string/business_information" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/page_horizontal_padding"
                android:paddingEnd="@dimen/page_horizontal_padding">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/registrationNumberLayout"
                    style="@style/Widget.InventoryHub.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/registration_number">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/registrationNumberEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapCharacters" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/addressLayout"
                    style="@style/Widget.InventoryHub.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:hint="@string/address">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/addressEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords|textPostalAddress|textMultiLine"
                        android:maxLines="4"
                        android:minLines="2" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/contactLayout"
                    style="@style/Widget.InventoryHub.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:hint="@string/contact">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/contactEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/phoneLayout"
                    style="@style/Widget.InventoryHub.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:hint="@string/phone">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/phoneEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/saveButton"
                    style="@style/Widget.InventoryHub.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_lg"
                    android:text="@string/save_changes" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/space_md"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
