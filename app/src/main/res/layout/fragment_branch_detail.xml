<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/inventory_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/branchDetailToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIconTint="@color/inventory_text_primary"
            app:titleTextColor="@color/inventory_text_primary"
            tools:title="Location" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/page_horizontal_padding"
            android:paddingTop="@dimen/space_md"
            android:paddingEnd="@dimen/page_horizontal_padding"
            android:paddingBottom="@dimen/space_sm"
            android:text="@string/location_details"
            android:textColor="@color/inventory_text_secondary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/page_horizontal_padding"
            android:paddingEnd="@dimen/page_horizontal_padding"
            android:paddingBottom="@dimen/page_bottom_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/space_md">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/name"
                    android:textColor="@color/inventory_text_secondary"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/nameValueTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/inventory_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    tools:text="Puchong" />
            </LinearLayout>

            <View style="@style/Widget.InventoryHub.FormDivider" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:gravity="top"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/space_md">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/memo"
                    android:textColor="@color/inventory_text_secondary"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/memoValueTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:maxWidth="220dp"
                    android:textAlignment="viewEnd"
                    android:textColor="@color/inventory_text_primary"
                    android:textSize="17sp"
                    tools:text="Front area store location." />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
