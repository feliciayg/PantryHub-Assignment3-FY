<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/inventory_surface"
    android:orientation="vertical"
    tools:context=".ui.restock.PurchaseDetailFragment">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/app_bar_height"
        android:background="@color/inventory_surface"
        app:navigationIcon="@drawable/ic_back"
        app:menu="@menu/menu_purchase_detail"
        app:titleCentered="true"
        app:titleTextColor="@color/inventory_text_primary"
        tools:title="PO-000005" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inventory_outline" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/page_horizontal_padding"
                android:paddingTop="@dimen/space_lg"
                android:paddingEnd="@dimen/page_horizontal_padding">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/order_status"
                        android:textColor="@color/inventory_text_secondary"
                        android:textSize="@dimen/text_size_body" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:gravity="start"
                        android:orientation="horizontal">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/statusChip"
                            style="@style/Widget.InventoryHub.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:paddingStart="0dp"
                            android:paddingEnd="0dp"
                            android:textColor="@color/inventory_text_primary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            app:chipCornerRadius="16dp"
                            app:chipMinHeight="32dp"
                            app:chipStrokeWidth="0dp"
                            app:ensureMinTouchTargetSize="false"
                            app:textStartPadding="14dp"
                            app:textEndPadding="14dp"
                            tools:text="Ordered" />
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/order_date"
                        android:textColor="@color/inventory_text_secondary"
                        android:textSize="@dimen/text_size_body" />

                    <TextView
                        android:id="@+id/orderDateTextView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:textColor="@color/inventory_text_primary"
                        android:textSize="@dimen/text_size_body"
                        tools:text="June 13, 2026 5:24 AM" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/expected_date"
                        android:textColor="@color/inventory_text_secondary"
                        android:textSize="@dimen/text_size_body" />

                    <TextView
                        android:id="@+id/expectedDateTextView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:textColor="@color/inventory_text_primary"
                        android:textSize="@dimen/text_size_body"
                        tools:text="June 17, 2026" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/receiving_location"
                        android:textColor="@color/inventory_text_secondary"
                        android:textSize="@dimen/text_size_body" />

                    <TextView
                        android:id="@+id/receivingLocationTextView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:textColor="@color/inventory_text_primary"
                        android:textSize="@dimen/text_size_body"
                        tools:text="Puchong Branch" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/supplier"
                        android:textColor="@color/inventory_text_secondary"
                        android:textSize="@dimen/text_size_body" />

                    <TextView
                        android:id="@+id/supplierTextView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:textColor="@color/inventory_text_primary"
                        android:textSize="@dimen/text_size_body"
                        tools:text="Ali sdnbhd" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/created_by"
                        android:textColor="@color/inventory_text_secondary"
                        android:textSize="@dimen/text_size_body" />

                    <TextView
                        android:id="@+id/createdByTextView"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:textColor="@color/inventory_text_primary"
                        android:textSize="@dimen/text_size_body"
                        tools:text="Felicia" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/space_sm"
                android:layout_marginTop="@dimen/space_lg"
                android:background="@color/inventory_background" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/detailsTabTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:paddingTop="@dimen/space_lg"
                    android:paddingBottom="@dimen/space_lg"
                    android:text="@string/details"
                    android:textColor="@color/inventory_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/statusTabTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:paddingTop="@dimen/space_lg"
                    android:paddingBottom="@dimen/space_lg"
                    android:text="@string/status"
                    android:textColor="@color/inventory_text_secondary"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:orientation="horizontal">

                <View
                    android:id="@+id/detailsTabIndicator"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@color/inventory_primary" />

                <View
                    android:id="@+id/statusTabIndicator"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/inventory_outline" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/itemsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingStart="@dimen/page_horizontal_padding"
                android:paddingTop="@dimen/space_md"
                android:paddingEnd="@dimen/page_horizontal_padding"
                tools:listitem="@layout/item_purchase_detail_entry" />

            <LinearLayout
                android:id="@+id/statusSummaryContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="@dimen/page_horizontal_padding"
                android:paddingTop="@dimen/space_lg"
                android:paddingEnd="@dimen/page_horizontal_padding"
                android:paddingBottom="@dimen/space_lg"
                android:visibility="gone">

                <TextView
                    android:id="@+id/statusSummaryItemsTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/inventory_text_primary"
                    android:textSize="@dimen/text_size_section"
                    android:textStyle="bold"
                    tools:text="1 item" />

                <TextView
                    android:id="@+id/statusSummaryQuantityTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/inventory_text_primary"
                    android:textSize="@dimen/text_size_section"
                    android:textStyle="bold"
                    tools:text="20/50" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/space_sm"
                android:layout_marginTop="@dimen/space_lg"
                android:background="@color/inventory_background" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/page_horizontal_padding"
                android:paddingTop="@dimen/space_lg"
                android:paddingEnd="@dimen/page_horizontal_padding"
                android:text="@string/received_items"
                android:textColor="@color/inventory_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/emptyReceivedItemsTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="@dimen/space_xl"
                android:paddingBottom="@dimen/space_xl"
                android:text="@string/no_results_found"
                android:textColor="@color/inventory_text_secondary" />

            <LinearLayout
                android:id="@+id/receivedEventsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/page_horizontal_padding"
                android:paddingTop="@dimen/space_md"
                android:paddingEnd="@dimen/page_horizontal_padding"
                android:paddingBottom="@dimen/space_lg" />

            <LinearLayout
                android:id="@+id/totalsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:orientation="vertical"
                android:paddingStart="@dimen/page_horizontal_padding"
                android:paddingEnd="@dimen/page_horizontal_padding">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/inventory_outline" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="@dimen/space_lg"
                    android:paddingBottom="@dimen/space_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/subtotal"
                            android:textColor="@color/inventory_text_secondary"
                            android:textSize="@dimen/text_size_body" />

                        <TextView
                            android:id="@+id/subtotalTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/inventory_text_primary"
                            android:textSize="@dimen/text_size_body"
                            tools:text="RM10.00" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/total_myr"
                            android:textColor="@color/inventory_text_primary"
                            android:textSize="@dimen/text_size_section"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/totalTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/inventory_text_primary"
                            android:textSize="@dimen/text_size_section"
                            android:textStyle="bold"
                            tools:text="RM10.00" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/receiveActionsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/inventory_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/page_horizontal_padding"
        android:paddingTop="@dimen/space_md"
        android:paddingEnd="@dimen/page_horizontal_padding"
        android:paddingBottom="@dimen/space_lg">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/partiallyReceiveButton"
            style="@style/Widget.InventoryHub.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_standard_height"
            android:layout_weight="1"
            android:text="@string/partially_receive" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/receiveAllButton"
            style="@style/Widget.InventoryHub.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_standard_height"
            android:layout_marginStart="@dimen/space_md"
            android:layout_weight="1"
            android:text="@string/receive_all" />
    </LinearLayout>
</LinearLayout>
