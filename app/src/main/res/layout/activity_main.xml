<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainContent"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/inventory_background"
    android:orientation="vertical"
    tools:context=".MainActivity"
    tools:theme="@style/Theme.InventoryHub">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/inventory_surface"
        app:elevation="@dimen/app_bar_elevation">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/topAppBar"
            style="@style/Widget.InventoryHub.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/app_bar_height"
            app:title="@string/app_name">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/profileToolbarButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="end|center_vertical"
                android:clickable="true"
                android:contentDescription="@string/profile"
                android:focusable="true"
                android:visibility="gone"
                app:cardBackgroundColor="@color/inventory_success"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/profileToolbarInitialTextView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="F" />
            </com.google.android.material.card.MaterialCardView>

            <ImageButton
                android:id="@+id/transactionsFilterButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end|center_vertical"
                android:background="@null"
                android:contentDescription="@string/filter_transactions"
                android:src="@drawable/ic_filter"
                android:visibility="gone"
                app:tint="@color/inventory_text_primary"
                tools:visibility="visible" />

            <ImageButton
                android:id="@+id/archiveToolbarButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end|center_vertical"
                android:background="@null"
                android:contentDescription="@string/view_archived_items"
                android:src="@drawable/ic_archive"
                android:visibility="gone"
                app:tint="@color/inventory_text_primary"
                tools:visibility="visible" />

            <ImageButton
                android:id="@+id/helpToolbarButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end|center_vertical"
                android:background="@null"
                android:contentDescription="@string/help"
                android:src="@drawable/ic_help"
                android:visibility="gone"
                app:tint="@color/inventory_text_primary"
                tools:visibility="visible" />
        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/navHostFragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_graph"
        tools:layout="@layout/fragment_home" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        style="@style/Widget.InventoryHub.BottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_navigation_height"
        app:menu="@menu/bottom_nav_menu" />
</LinearLayout>
