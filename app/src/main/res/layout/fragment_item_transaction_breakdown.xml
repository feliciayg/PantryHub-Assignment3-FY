<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/inventory_background"
    android:orientation="vertical"
    tools:theme="@style/Theme.InventoryHub">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/app_bar_height"
        android:background="@color/inventory_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/space_sm"
        android:paddingEnd="@dimen/space_sm">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            android:src="@drawable/ic_back"
            app:tint="@color/inventory_text_primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/locationButton"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/all_locations"
            android:textColor="@color/inventory_text_primary"
            android:textSize="@dimen/text_size_section"
            android:textStyle="bold"
            app:icon="@drawable/ic_chevron_down"
            app:iconGravity="textEnd"
            app:iconTint="@color/inventory_text_primary" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inventory_outline" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/page_bottom_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/page_horizontal_padding"
            android:paddingTop="@dimen/space_lg"
            android:paddingEnd="@dimen/page_horizontal_padding">

            <!-- Month Header -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/monthTitleTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textColor="@color/inventory_text_primary"
                    android:textSize="@dimen/text_size_title"
                    android:textStyle="bold"
                    tools:text="June 2026"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/previousMonthButton" />

                <ImageButton
                    android:id="@+id/previousMonthButton"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_icon_circle"
                    android:contentDescription="@string/previous_month"
                    android:src="@drawable/ic_back"
                    app:tint="@color/inventory_text_primary"
                    app:layout_constraintEnd_toStartOf="@id/nextMonthButton"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <ImageButton
                    android:id="@+id/nextMonthButton"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginStart="@dimen/space_sm"
                    android:background="@drawable/bg_icon_circle"
                    android:contentDescription="@string/next_month"
                    android:rotation="180"
                    android:src="@drawable/ic_back"
                    app:tint="@color/inventory_text_primary"
                    app:layout_constraintEnd_toStartOf="@id/todayButton"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/todayButton"
                    style="@style/Widget.InventoryHub.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginStart="@dimen/space_md"
                    android:minHeight="44dp"
                    android:text="@string/today"
                    android:textColor="@color/inventory_primary"
                    app:backgroundTint="@color/inventory_primary_container"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.InventoryHub.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                app:cardElevation="0dp"
                app:strokeColor="@color/inventory_outline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Mon"
                            android:textColor="@color/inventory_nav_unselected"
                            android:textSize="@dimen/text_size_caption"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Tue"
                            android:textColor="@color/inventory_nav_unselected"
                            android:textSize="@dimen/text_size_caption"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Wed"
                            android:textColor="@color/inventory_nav_unselected"
                            android:textSize="@dimen/text_size_caption"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Thu"
                            android:textColor="@color/inventory_nav_unselected"
                            android:textSize="@dimen/text_size_caption"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Fri"
                            android:textColor="@color/inventory_nav_unselected"
                            android:textSize="@dimen/text_size_caption"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Sat"
                            android:textColor="@color/inventory_nav_unselected"
                            android:textSize="@dimen/text_size_caption"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Sun"
                            android:textColor="@color/inventory_nav_unselected"
                            android:textSize="@dimen/text_size_caption"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/calendarRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="324dp"
                        android:layout_marginTop="@dimen/space_sm"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/selectedDateTitleTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:textColor="@color/inventory_text_primary"
                android:textSize="@dimen/text_size_section"
                android:textStyle="bold"
                tools:text="14 Jun 2026" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/transactionsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/emptyTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:background="@drawable/bg_inventory_image_placeholder"
                android:gravity="center"
                android:padding="@dimen/space_md"
                android:text="@string/no_transactions_on_this_date"
                android:textColor="@color/inventory_text_secondary"
                android:visibility="gone" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
