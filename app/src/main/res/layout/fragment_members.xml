<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/inventory_background"
    android:orientation="vertical"
    tools:theme="@style/Theme.InventoryHub">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        style="@style/Widget.InventoryHub.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/app_bar_height"
        app:navigationIcon="@drawable/ic_back"
        app:title="@string/settings_members" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inventory_outline" />

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.InventoryHub.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/page_horizontal_padding"
        android:layout_marginTop="@dimen/space_lg"
        android:layout_marginEnd="@dimen/page_horizontal_padding"
        app:cardElevation="0dp"
        app:strokeColor="@color/inventory_outline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/card_padding">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/invite_code"
                android:textColor="@color/inventory_text_secondary"
                android:textSize="@dimen/text_size_body"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/inviteCodeStoreTextView"
                style="@style/TextAppearance.InventoryHub.Caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                tools:text="Share this code with staff joining JayaGrocer." />

            <TextView
                android:id="@+id/inviteCodeValueTextView"
                style="@style/TextAppearance.InventoryHub.PageTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:textColor="@color/inventory_primary"
                tools:text="A1B2C3" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/copyCodeButton"
                    style="@style/Widget.InventoryHub.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/copy_code" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/shareCodeButton"
                    style="@style/Widget.InventoryHub.Button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_sm"
                    android:layout_weight="1"
                    android:text="@string/share_code" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/page_horizontal_padding"
        android:paddingTop="@dimen/space_lg"
        android:paddingEnd="@dimen/page_horizontal_padding"
        android:paddingBottom="@dimen/space_md">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/members_in_store"
            android:textColor="@color/inventory_text_secondary"
            android:textSize="@dimen/text_size_body"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/memberCountTextView"
            style="@style/TextAppearance.InventoryHub.Caption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_countdown_chip"
            android:layout_marginStart="@dimen/space_sm"
            android:paddingStart="@dimen/space_sm"
            android:paddingTop="@dimen/space_xs"
            android:paddingEnd="@dimen/space_sm"
            android:paddingBottom="@dimen/space_xs"
            android:textColor="@color/inventory_on_primary"
            tools:text="3" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/membersRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="@dimen/page_horizontal_padding"
        android:paddingTop="@dimen/space_md"
        android:paddingEnd="@dimen/page_horizontal_padding"
        android:paddingBottom="@dimen/page_bottom_padding"
        tools:itemCount="3"
        tools:listitem="@layout/item_staff_member" />

    <TextView
        android:id="@+id/emptyTextView"
        style="@style/TextAppearance.InventoryHub.Body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingStart="@dimen/page_horizontal_padding"
        android:paddingTop="@dimen/space_xl"
        android:paddingEnd="@dimen/page_horizontal_padding"
        android:paddingBottom="@dimen/space_xl"
        android:text="@string/no_members_yet"
        android:textColor="@color/inventory_text_secondary"
        android:visibility="gone" />
</LinearLayout>
