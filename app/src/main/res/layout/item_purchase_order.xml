<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:minHeight="148dp"
    android:orientation="vertical"
    android:paddingStart="@dimen/page_horizontal_padding"
    android:paddingTop="22dp"
    android:paddingEnd="@dimen/page_horizontal_padding"
    android:paddingBottom="22dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/orderNumberTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/inventory_text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            tools:text="PO-000005" />

        <com.google.android.material.chip.Chip
            android:id="@+id/statusChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:textColor="@color/inventory_text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:chipCornerRadius="16dp"
            app:chipMinHeight="32dp"
            app:chipStrokeWidth="0dp"
            app:ensureMinTouchTargetSize="false"
            app:textStartPadding="14dp"
            app:textEndPadding="14dp"
            style="@style/Widget.InventoryHub.Chip.Assist"
            tools:text="Partially Received" />

        <TextView
            android:id="@+id/archivedBadgeTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_sm"
            android:background="@drawable/bg_group_percentage_badge"
            android:paddingStart="@dimen/space_sm"
            android:paddingTop="2dp"
            android:paddingEnd="@dimen/space_sm"
            android:paddingBottom="2dp"
            android:text="@string/archived"
            android:textColor="@color/inventory_text_secondary"
            android:textSize="@dimen/text_size_small"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:orientation="horizontal">

            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="@string/date"
                android:textColor="@color/inventory_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/orderDateValueTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/inventory_text_primary"
                android:textSize="14sp"
                tools:text="June 13, 2026 5:15 AM" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="top"
            android:orientation="horizontal">

            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="@string/supplier"
                android:textColor="@color/inventory_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/supplierValueTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/inventory_text_primary"
                android:textSize="14sp"
                tools:text="Ali sdnbhd" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="top"
            android:orientation="horizontal">

            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="@string/location"
                android:textColor="@color/inventory_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/locationValueTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/inventory_text_primary"
                android:textSize="14sp"
                tools:text="Puchong" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="top"
            android:orientation="horizontal">

            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="@string/items_section"
                android:textColor="@color/inventory_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/itemsValueTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/inventory_text_primary"
                android:textSize="14sp"
                tools:text="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="top"
            android:orientation="horizontal">

            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="@string/total"
                android:textColor="@color/inventory_text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/totalValueTextView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/inventory_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="RM10.00" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="22dp"
        android:background="@color/inventory_outline" />
</LinearLayout>
