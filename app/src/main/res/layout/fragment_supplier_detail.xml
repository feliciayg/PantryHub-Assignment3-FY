<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/inventory_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/supplierDetailToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIconTint="@color/inventory_text_primary"
            app:titleTextColor="@color/inventory_text_primary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/page_horizontal_padding"
            android:paddingTop="@dimen/space_md"
            android:paddingEnd="@dimen/page_horizontal_padding"
            android:paddingBottom="@dimen/page_bottom_padding">

            <LinearLayout
                android:id="@+id/nameRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/space_md">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/name"
                    android:textColor="@color/inventory_text_secondary"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/nameValueTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/inventory_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    tools:text="smith" />
            </LinearLayout>

            <View style="@style/Widget.InventoryHub.FormDivider" />

            <LinearLayout
                android:id="@+id/phoneRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/space_md">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/phone"
                    android:textColor="@color/inventory_text_secondary"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/phoneValueTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:gravity="end"
                    android:maxLines="1"
                    android:textColor="@color/inventory_text_primary"
                    android:textSize="17sp"
                    tools:text="10768450" />

                <ImageButton
                    android:id="@+id/callButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="@dimen/space_sm"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/call_supplier"
                    android:padding="6dp"
                    android:src="@drawable/ic_call"
                    app:tint="@color/inventory_text_secondary" />
            </LinearLayout>

            <View style="@style/Widget.InventoryHub.FormDivider" />

            <LinearLayout
                android:id="@+id/emailRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="@dimen/space_md">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/email"
                    android:textColor="@color/inventory_text_secondary"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/emailValueTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:gravity="end"
                    android:maxLines="1"
                    android:textColor="@color/inventory_text_primary"
                    android:textSize="17sp"
                    tools:text="None" />

                <ImageButton
                    android:id="@+id/emailButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="@dimen/space_sm"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/email_supplier"
                    android:padding="6dp"
                    android:src="@drawable/ic_email"
                    app:tint="@color/inventory_text_secondary" />
            </LinearLayout>

            <View style="@style/Widget.InventoryHub.FormDivider" />

            <LinearLayout
                android:id="@+id/addressRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="@dimen/space_md"
                android:paddingBottom="@dimen/space_md">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/address"
                    android:textColor="@color/inventory_text_secondary"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/addressValueTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:gravity="end"
                    android:textColor="@color/inventory_text_primary"
                    android:textSize="17sp"
                    tools:text="Not added" />
            </LinearLayout>

            <View style="@style/Widget.InventoryHub.FormDivider" />

            <LinearLayout
                android:id="@+id/memoRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="@dimen/space_md"
                android:paddingBottom="@dimen/space_md">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/memo"
                    android:textColor="@color/inventory_text_secondary"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/memoValueTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:gravity="end"
                    android:textColor="@color/inventory_text_primary"
                    android:textSize="17sp"
                    tools:text="No notes added." />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
