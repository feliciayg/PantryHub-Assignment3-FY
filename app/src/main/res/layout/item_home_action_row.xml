<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="@dimen/home_action_row_height"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="@dimen/card_padding"
    android:paddingEnd="@dimen/card_padding">

    <ImageView
        android:id="@+id/actionIcon"
        android:layout_width="@dimen/home_action_icon_size"
        android:layout_height="@dimen/home_action_icon_size"
        android:contentDescription="@null"
        tools:src="@drawable/ic_add" />

    <TextView
        android:id="@+id/actionLabel"
        style="@style/TextAppearance.InventoryHub.Body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_md"
        android:layout_weight="1"
        tools:text="Add Item" />

    <ImageView
        android:layout_width="@dimen/home_action_icon_size"
        android:layout_height="@dimen/home_action_icon_size"
        android:contentDescription="@null"
        android:src="@drawable/ic_chevron_right"
        app:tint="@color/inventory_text_secondary" />
</LinearLayout>
