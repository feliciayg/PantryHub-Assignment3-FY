<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:minHeight="84dp"
    android:orientation="horizontal"
    android:paddingVertical="@dimen/space_md">

    <ImageView
        android:id="@+id/partnerTypeIconView"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:contentDescription="@null"
        app:tint="@color/inventory_outline"
        android:src="@drawable/ic_restock" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/space_md"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/nameTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/inventory_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/contactTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:textColor="@color/inventory_text_secondary"
            android:textSize="@dimen/text_size_body" />

        <TextView
            android:id="@+id/archivedBadgeTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:background="@drawable/bg_group_percentage_badge"
            android:paddingStart="@dimen/space_sm"
            android:paddingTop="2dp"
            android:paddingEnd="@dimen/space_sm"
            android:paddingBottom="2dp"
            android:text="@string/archived"
            android:textColor="@color/inventory_text_secondary"
            android:textSize="@dimen/text_size_small"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/favoriteButton"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/partners_favorite"
        android:padding="6dp"
        android:src="@drawable/ic_star_outline"
        app:tint="@color/inventory_outline" />
</LinearLayout>
