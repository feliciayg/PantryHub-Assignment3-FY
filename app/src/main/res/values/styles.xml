<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.InventoryHub.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/inventory_primary</item>
        <item name="iconTint">@color/white</item>
        <item name="android:textColor">@color/white</item>
        <item name="rippleColor">@android:color/transparent</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="Widget.InventoryHub.Button.Primary" parent="Widget.InventoryHub.Button">
        <item name="backgroundTint">@color/inventory_primary</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.InventoryHub.Button.Secondary" parent="Widget.InventoryHub.Button.Outlined">
        <item name="android:textColor">@color/inventory_outlined_button_content</item>
    </style>

    <style name="Widget.InventoryHub.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/inventory_primary</item>
        <item name="iconTint">@color/inventory_outlined_button_content</item>
        <item name="android:textColor">@color/inventory_outlined_button_content</item>
        <item name="rippleColor">@android:color/transparent</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="Widget.InventoryHub.Button.AuthPrimary" parent="Widget.InventoryHub.Button">
        <item name="cornerRadius">@dimen/auth_button_corner_radius</item>
        <item name="android:minHeight">60dp</item>
        <item name="backgroundTint">@color/inventory_primary</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.InventoryHub.Button.AuthOutlined" parent="Widget.InventoryHub.Button.Outlined">
        <item name="cornerRadius">@dimen/auth_button_corner_radius</item>
        <item name="android:minHeight">58dp</item>
        <item name="strokeColor">@color/inventory_outline</item>
        <item name="android:textColor">@color/inventory_text_primary</item>
    </style>

    <style name="Widget.InventoryHub.Card" parent="Widget.Material3.CardView.Outlined">
        <item name="android:foreground">@null</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardBackgroundColor">@color/inventory_surface</item>
        <item name="strokeColor">@color/inventory_outline</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardElevation">0dp</item>
        <item name="rippleColor">@android:color/transparent</item>
    </style>

    <style name="Widget.InventoryHub.HomeCard" parent="Widget.Material3.CardView.Outlined">
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="cardCornerRadius">@dimen/home_card_corner_radius</item>
        <item name="cardBackgroundColor">@color/inventory_surface</item>
        <item name="strokeColor">@color/inventory_outline</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardElevation">0dp</item>
        <item name="rippleColor">@android:color/transparent</item>
    </style>

    <style name="Widget.InventoryHub.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:paddingStart">@dimen/space_sm</item>
        <item name="android:paddingEnd">@dimen/page_horizontal_padding</item>
        <item name="navigationIconTint">@color/inventory_text_primary</item>
        <item name="titleTextAppearance">@style/TextAppearance.InventoryHub.ToolbarTitle</item>
        <item name="titleTextColor">@color/inventory_text_primary</item>
    </style>

    <style name="Widget.InventoryHub.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/inventory_surface_muted</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.InventoryHub.BottomNavigation.ActiveIndicator</item>
        <item name="itemIconSize">@dimen/bottom_navigation_icon_size</item>
        <item name="itemPaddingBottom">@dimen/space_sm</item>
        <item name="itemPaddingTop">@dimen/space_xs</item>
        <item name="itemIconTint">@color/inventory_bottom_nav_item</item>
        <item name="itemTextColor">@color/inventory_bottom_nav_item</item>
        <item name="itemTextAppearanceActive">@style/TextAppearance.InventoryHub.BottomNavigation.Active</item>
        <item name="itemTextAppearanceInactive">@style/TextAppearance.InventoryHub.BottomNavigation.Inactive</item>
        <item name="itemRippleColor">@android:color/transparent</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemHorizontalTranslationEnabled">false</item>
        <item name="elevation">4dp</item>
    </style>

    <style name="Widget.InventoryHub.BottomNavigation.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/inventory_nav_selected_background</item>
    </style>

    <style name="Widget.InventoryHub.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="android:foreground">@null</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="chipCornerRadius">@dimen/button_corner_radius</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipBackgroundColor">@color/inventory_chip_background</item>
        <item name="chipStrokeColor">@color/inventory_control_tint</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/inventory_chip_text</item>
        <item name="chipIconTint">@color/inventory_control_tint</item>
        <item name="checkedIconTint">@color/inventory_control_tint</item>
        <item name="rippleColor">@android:color/transparent</item>
        <item name="showMotionSpec">@null</item>
        <item name="hideMotionSpec">@null</item>
    </style>

    <style name="Widget.InventoryHub.Chip.Assist" parent="Widget.Material3.Chip.Assist">
        <item name="android:foreground">@null</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="chipCornerRadius">@dimen/button_corner_radius</item>
        <item name="chipBackgroundColor">@color/inventory_chip_background</item>
        <item name="chipStrokeColor">@color/inventory_control_tint</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/inventory_chip_text</item>
        <item name="chipIconTint">@color/inventory_control_tint</item>
        <item name="checkedIconTint">@color/inventory_control_tint</item>
        <item name="rippleColor">@android:color/transparent</item>
        <item name="showMotionSpec">@null</item>
        <item name="hideMotionSpec">@null</item>
    </style>

    <style name="ThemeOverlay.InventoryHub.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/inventory_surface_overlay</item>
        <item name="backgroundTint">@color/inventory_surface_overlay</item>
    </style>

    <style name="ThemeOverlay.InventoryHub.BottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.InventoryHub.BottomSheet.Modal</item>
    </style>

    <style name="Widget.InventoryHub.BottomSheet.Modal" parent="Widget.Material3.BottomSheet.Modal">
        <item name="android:background">@color/inventory_surface_overlay</item>
        <item name="backgroundTint">@color/inventory_surface_overlay</item>
    </style>

    <style name="TextAppearance.InventoryHub.ToolbarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/inventory_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.InventoryHub.PageTitle" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textColor">@color/inventory_text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.InventoryHub.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/inventory_text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.InventoryHub.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/inventory_text_primary</item>
    </style>

    <style name="TextAppearance.InventoryHub.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/inventory_text_secondary</item>
    </style>

    <style name="TextAppearance.InventoryHub.BottomNavigation.Active" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:includeFontPadding">true</item>
        <item name="android:textSize">@dimen/text_size_bottom_nav</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.InventoryHub.BottomNavigation.Inactive" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:includeFontPadding">true</item>
        <item name="android:textSize">@dimen/text_size_bottom_nav</item>
    </style>

    <style name="Widget.InventoryHub.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="android:minHeight">@dimen/form_field_height</item>
        <item name="boxCornerRadiusTopStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/input_corner_radius</item>
        <item name="boxBackgroundColor">@color/inventory_surface_overlay</item>
        <item name="boxStrokeColor">@color/inventory_text_input_stroke</item>
        <item name="hintTextColor">@color/inventory_text_secondary</item>
        <item name="endIconTint">@color/inventory_control_tint</item>
        <item name="android:textColorHint">@color/inventory_text_secondary</item>
        <item name="simpleItemSelectedColor">@android:color/transparent</item>
        <item name="simpleItemSelectedRippleColor">@android:color/transparent</item>
        <item name="simpleItemLayout">@layout/item_dropdown_menu_white</item>
    </style>

    <style name="Widget.InventoryHub.TextInput.Auth" parent="Widget.InventoryHub.TextInput">
        <item name="boxCornerRadiusTopStart">@dimen/space_xs</item>
        <item name="boxCornerRadiusTopEnd">@dimen/space_xs</item>
        <item name="boxCornerRadiusBottomStart">@dimen/space_xs</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/space_xs</item>
        <item name="boxStrokeColor">@color/inventory_outline</item>
        <item name="startIconTint">@color/inventory_text_secondary</item>
        <item name="endIconTint">@color/inventory_text_secondary</item>
    </style>

    <style name="Widget.InventoryHub.RadioButton" parent="Widget.Material3.CompoundButton.RadioButton">
        <item name="buttonTint">@color/inventory_control_tint</item>
    </style>

    <style name="Widget.InventoryHub.CheckBox" parent="Widget.Material3.CompoundButton.CheckBox">
        <item name="android:button">@drawable/selector_checkbox_green_tick</item>
        <item name="buttonTint">@null</item>
        <item name="android:buttonTint">@null</item>
        <item name="rippleColor">@android:color/transparent</item>
    </style>

    <style name="Widget.InventoryHub.FloatingActionButton" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/inventory_primary</item>
        <item name="tint">@color/white</item>
        <item name="rippleColor">@android:color/transparent</item>
    </style>

    <style name="Widget.InventoryHub.FormRow" parent="@android:style/Widget">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/item_form_row_height</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">@dimen/item_form_horizontal_padding</item>
        <item name="android:paddingEnd">@dimen/item_form_horizontal_padding</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="Widget.InventoryHub.FormRowLabel" parent="@android:style/Widget.TextView">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/inventory_text_secondary</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:singleLine">true</item>
    </style>

    <style name="Widget.InventoryHub.FormRowValue" parent="@android:style/Widget.TextView">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:singleLine">true</item>
        <item name="android:textColor">@color/inventory_text_primary</item>
        <item name="android:textColorHint">@color/inventory_text_secondary</item>
        <item name="android:textSize">@dimen/text_size_body</item>
    </style>

    <style name="Widget.InventoryHub.FormRowChevron" parent="@android:style/Widget">
        <item name="android:layout_width">@dimen/home_status_icon_size</item>
        <item name="android:layout_height">@dimen/home_status_icon_size</item>
        <item name="android:layout_marginStart">@dimen/space_sm</item>
        <item name="android:contentDescription">@null</item>
        <item name="android:src">@drawable/ic_chevron_right</item>
        <item name="tint">@color/inventory_text_secondary</item>
    </style>

    <style name="Widget.InventoryHub.FormDivider" parent="@android:style/Widget">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginStart">@dimen/item_form_horizontal_padding</item>
        <item name="android:layout_marginEnd">@dimen/item_form_horizontal_padding</item>
        <item name="android:background">@color/inventory_outline</item>
    </style>

    <style name="Widget.InventoryHub.SectionBand" parent="@android:style/Widget">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">10dp</item>
        <item name="android:layout_marginTop">@dimen/space_sm</item>
        <item name="android:background">@color/inventory_surface_muted</item>
    </style>

    <style name="Widget.InventoryHub.FormSectionTitle" parent="@android:style/Widget.TextView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingStart">@dimen/item_form_horizontal_padding</item>
        <item name="android:paddingTop">@dimen/space_lg</item>
        <item name="android:paddingEnd">@dimen/item_form_horizontal_padding</item>
        <item name="android:paddingBottom">@dimen/space_md</item>
        <item name="android:textColor">@color/inventory_text_primary</item>
        <item name="android:textSize">@dimen/text_size_section</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
