    <string name="help_topic_getting_started">Getting Started</string>
    <string name="help_answer_getting_started">Create your store, add locations, then add a few items so the dashboard and transactions have data to work with.</string>
    <string name="help_topic_add_item">How do I add an item?</string>
    <string name="help_answer_add_item">Open Items, tap the add button, fill in the item details, then save. You can add category, brand, supplier, and stock levels later too.</string>
    <string name="help_topic_stock_in">How do I do Stock In?</string>
    <string name="help_answer_stock_in">Go to Transactions, choose Stock In, pick the location and item, enter the quantity, then submit to increase stock.</string>
    <string name="help_topic_stock_out">How do I do Stock Out?</string>
    <string name="help_answer_stock_out">Go to Transactions, choose Stock Out, select the item and location, then enter how much stock is leaving.</string>
    <string name="help_topic_move_stock">How do I move stock between locations?</string>
    <string name="help_answer_move_stock">Use Move Stock in Transactions, choose the source and destination locations, then confirm the quantity to transfer.</string>
    <string name="help_topic_adjust_stock">How do I adjust stock?</string>
    <string name="help_answer_adjust_stock">Use Adjust Stock when the real count is different from the system. Enter the corrected quantity and a short reason if needed.</string>
    <string name="help_topic_create_purchase_order">How do I create a purchase order?</string>
    <string name="help_answer_create_purchase_order">Open Purchases, tap add, choose the supplier and receiving location, add items, then save the order as draft or submit it.</string>
    <string name="help_topic_receive_purchase_items">How do I receive purchase items?</string>
    <string name="help_answer_receive_purchase_items">Open a purchase order, choose receive, then enter the quantities that arrived. Stock only increases for the items you receive.</string>
    <string name="help_topic_shortages">How do shortages / safety stock work?</string>
    <string name="help_answer_shortages">Items below their reorder or safety stock level appear as shortages so you can restock them before they run out.</string>
    <string name="help_topic_expiry_dates">How do expiry dates work?</string>
    <string name="help_answer_expiry_dates">Expiry dates help you see expiring and expired stock. Expired stock stays visible until you remove it with Mark Expired.</string>
    <string name="help_topic_csv_import_export">How do CSV import and export work?</string>
    <string name="help_answer_csv_import_export">Use the Items screen menu to import or export inventory CSV files. Sales CSV import deducts sold quantities from matching items.</string>
